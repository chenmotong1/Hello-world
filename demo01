import re
def parse_stock_raw(raw:str) -> tuple[str,str]:
    m = re.search(r'\d{6}',raw)
    print(m)
    code = m.group()
    print(code)
    name = raw.replace(code,'').replace('(','').replace(')','')
    return (name,code)

