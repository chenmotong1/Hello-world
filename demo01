def paginate_fetch(max_pages,empty_page = 4):
    for page in range(1,max_pages+1):
        
        if page == empty_page:
            print(f"第{page}页无数据，停止")
            print(f"总共抓取{page-1}页数据")
            break
        print(f"正在抓取第{page}页")

