def classify_stock(code:str) -> str:
    code = int(code[0])
    if code == 6:
        return '沪市A股'
    elif code == 0:
        return '深市主板'
    elif code == 3:
        return '创业版'
    elif code == 8 or code == 4:
        return '北交所/新三板'
    
