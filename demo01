def format_stock_report(name,code,price,change_pct):
    if change_pct > 0:
        change_pct = '+' + str(change_pct)
    else:
        change_pct = str(change_pct)
    return f'{name}({code})当前价：{price} 跌涨幅:{change_pct}%'

